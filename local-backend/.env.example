# GAEY local voice backend configuration.
# Copy to local-backend/.env and edit. See doc/plan-a-selfhosted.md section E.

# Ollama (LLM runtime)
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.1:8b

# Whisper (STT)
WHISPER_MODEL=base.en
WHISPER_DEVICE=auto            # cpu | cuda | auto

# Kokoro (TTS)
KOKORO_VOICE=af_heart
TTS_SAMPLE_RATE=24000

# VAD / endpointing
VAD_SILENCE_MS=700

# Audio
INPUT_SAMPLE_RATE=16000

# CORS: comma-separated browser origins allowed to connect
ALLOW_ORIGINS=http://localhost:3000
