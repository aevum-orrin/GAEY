# --- Conversation backend selection ---
# 'elevenlabs' (default, cloud) or 'local' (self-hosted Plan A backend).
NEXT_PUBLIC_CONV_PROVIDER=elevenlabs
# Local Plan A backend WebSocket (used when NEXT_PUBLIC_CONV_PROVIDER=local).
NEXT_PUBLIC_LOCAL_WS_URL=ws://localhost:8000/ws

# --- ElevenLabs (used when NEXT_PUBLIC_CONV_PROVIDER=elevenlabs) ---
AGENT_ID=
XI_API_KEY=
